From 770bc427dd25583f4a53771448319bb7f49bdb2c Mon Sep 17 00:00:00 2001
From: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
Date: Wed, 24 Sep 2025 12:56:19 +0800
Subject: [PATCH] net: ethernet: mtk_ppe: dispatch short packets to high
 priority queue in PPPQ path

Dispatch TCP ACK short packets to a high-priority QDMA queue in PPPQ
mode. Without this, ETH-to-ETH throughput cannot reach line rate in
unbalanced PHY rate scenarios on MT7988.

The patch detects TCP ACK flows by comparing average packet sizes in
each conntrack direction. If the average is <= 64 bytes and smaller
than the reverse direction, the flow is classified as ACK-dominant and
its queue index is shifted up by 6 (from qid 3-8 to qid 9-14).

Also makes mtk_flow_entry_match_len() and mtk_flow_entry_match()
non-static so they can be called from mtk_ppe_offload.c, and adds
mtk_foe_entry_get_queue() for reading the current queue assignment.

Signed-off-by: Bo-Cun Chen <bc-bocun.chen@mediatek.com>
[ported from mtk-openwrt-feeds 25.12 patch ppe-11, kernel 6.12 to 6.18]
---
 drivers/net/ethernet/mediatek/mtk_ppe.c         |  18 +++-
 drivers/net/ethernet/mediatek/mtk_ppe.h         |   3 +
 drivers/net/ethernet/mediatek/mtk_ppe_debugfs.c |   2 +-
 drivers/net/ethernet/mediatek/mtk_ppe_offload.c |  96 +++++++++++++++-
 4 files changed, 110 insertions(+), 9 deletions(-)

--- a/drivers/net/ethernet/mediatek/mtk_ppe.c
+++ b/drivers/net/ethernet/mediatek/mtk_ppe.c
@@ -500,8 +500,17 @@ int mtk_foe_entry_set_queue(struct mtk_e
 	return 0;
 }
 
-static int
-mtk_flow_entry_match_len(struct mtk_eth *eth, struct mtk_foe_entry *entry)
+unsigned int mtk_foe_entry_get_queue(struct mtk_eth *eth, struct mtk_foe_entry *entry)
+{
+	u32 *ib2 = mtk_foe_entry_ib2(eth, entry);
+
+	if (mtk_is_netsys_v2_or_greater(eth))
+		return FIELD_GET(MTK_FOE_IB2_QID_V2, *ib2);
+
+	return FIELD_GET(MTK_FOE_IB2_QID, *ib2);
+}
+
+int mtk_flow_entry_match_len(struct mtk_eth *eth, struct mtk_foe_entry *entry)
 {
 	int type = mtk_get_ib1_pkt_type(eth, entry->ib1);
 
@@ -515,9 +524,8 @@ mtk_flow_entry_match_len(struct mtk_eth
 		return offsetof(struct mtk_foe_entry, ipv4.ib2);
 }
 
-static bool
-mtk_flow_entry_match(struct mtk_eth *eth, struct mtk_flow_entry *entry,
-		     struct mtk_foe_entry *data, int len)
+bool mtk_flow_entry_match(struct mtk_eth *eth, struct mtk_flow_entry *entry,
+			  struct mtk_foe_entry *data, int len)
 {
 	if ((data->ib1 ^ entry->data.ib1) & MTK_FOE_IB1_UDP)
 		return false;
--- a/drivers/net/ethernet/mediatek/mtk_ppe.h
+++ b/drivers/net/ethernet/mediatek/mtk_ppe.h
@@ -410,5 +410,8 @@ void mtk_foe_entry_get_stats(struct mtk_
 void mtk_foe_entry_get_stats(struct mtk_ppe *ppe, struct mtk_flow_entry *entry,
 			     int *idle);
 int mtk_ppe_internal_debugfs_init(struct mtk_eth *eth);
+int mtk_flow_entry_match_len(struct mtk_eth *eth, struct mtk_foe_entry *entry);
