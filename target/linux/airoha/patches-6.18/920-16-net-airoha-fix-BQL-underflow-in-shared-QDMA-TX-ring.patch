From: Lorenzo Bianconi <lorenzo@kernel.org>
Date: Fri, 20 Jun 2026 12:00:00 +0200
Subject: [PATCH] net: airoha: fix BQL underflow in shared QDMA TX ring

Adapted from upstream (20260620-airoha-bql-fixes-v3-1-76b95374e63e).

The original patch restructures the DMA lifecycle in ways that conflict
with out-of-tree patches in this tree.  This version keeps the existing
airoha_qdma_start()/airoha_qdma_stop() helpers but applies the BQL
accounting fixes:

- Clear e->skb in napi_poll before dma_unmap to prevent a stale pointer
  visible to the TX cleanup path.
- Add a flushing flag to airoha_queue; set it under the spinlock in
  airoha_qdma_cleanup_tx_queue() and check it early in airoha_dev_xmit()
  so no new descriptors are submitted while cleanup is in flight.
- Properly call netdev_tx_completed_queue() for every SKB freed during TX
  ring cleanup, instead of relying on netdev_tx_reset_subqueue() which
  races with in-flight BQL accounting and causes underflow.
- Reset flushing in airoha_qdma_start() so the ring is usable again after
  a down/up cycle.

Signed-off-by: Lorenzo Bianconi <lorenzo@kernel.org>
---
--- a/drivers/net/ethernet/airoha/airoha_eth.c	2026-06-21 11:14:00.691720640 +0000
+++ b/drivers/net/ethernet/airoha/airoha_eth.c	2026-06-21 11:15:29.194613008 +0000
@@ -1239,6 +1239,7 @@
 
 		e = &q->entry[index];
 		skb = e->skb;
+		e->skb = NULL;
 
 		dma_unmap_single(eth->dev, e->dma_addr, e->dma_len,
 				 DMA_TO_DEVICE);
@@ -1390,20 +1391,29 @@
 	u16 index = 0;
 
 	spin_lock_bh(&q->lock);
+	q->flushing = true;
 	for (i = 0; i < q->ndesc; i++) {
 		struct airoha_queue_entry *e = &q->entry[i];
 		struct airoha_qdma_desc *desc = &q->desc[i];
+		struct sk_buff *skb = e->skb;
 
 		if (!e->dma_addr)
 			continue;
 
 		dma_unmap_single(eth->dev, e->dma_addr, e->dma_len,
 				 DMA_TO_DEVICE);
-		dev_kfree_skb_any(e->skb);
 		e->dma_addr = 0;
 		e->skb = NULL;
 		list_add_tail(&e->list, &q->tx_list);
 
+		if (skb) {
+			struct netdev_queue *txq;
+
+			txq = skb_get_tx_queue(skb->dev, skb);
+			netdev_tx_completed_queue(txq, 1, skb->len);
+			dev_kfree_skb_any(skb);
+		}
+
 		/* Reset DMA descriptor */
 		WRITE_ONCE(desc->ctrl, 0);
 		WRITE_ONCE(desc->addr, 0);
@@ -2075,6 +2085,11 @@
 
 static void airoha_qdma_start(struct airoha_qdma *qdma)
 {
+	int i;
+
+	for (i = 0; i < ARRAY_SIZE(qdma->q_tx); i++)
+		qdma->q_tx[i].flushing = false;
+
 	airoha_qdma_set(qdma, REG_QDMA_GLOBAL_CFG,
 			GLOBAL_CFG_TX_DMA_EN_MASK |
 			GLOBAL_CFG_RX_DMA_EN_MASK);
@@ -2185,13 +2200,9 @@
 	struct airoha_gdm_dev *dev = netdev_priv(netdev);
 	struct airoha_gdm_port *port = dev->port;
 	struct airoha_qdma *qdma;
-	int i;
 
 	netif_tx_disable(netdev);
 	airoha_set_vip_for_gdm_port(dev, false);
-	for (i = 0; i < netdev->num_tx_queues; i++)
-		netdev_tx_reset_subqueue(netdev, i);
-
 	qdma = airoha_qdma_deref(dev);
 	if (--port->users)
 		airoha_ppe_set_mtu(dev);
@@ -2611,6 +2622,9 @@
 
 	spin_lock_bh(&q->lock);
 
+	if (q->flushing)
+		goto error_unlock;
+
 	txq = skb_get_tx_queue(netdev, skb);
 	nr_frags = 1 + skb_shinfo(skb)->nr_frags;
 
@@ -2694,7 +2708,7 @@
 		e->dma_addr = 0;
 	}
 	list_splice(&tx_list, &q->tx_list);
-
+error_unlock:
 	spin_unlock_bh(&q->lock);
 error:
 	dev_kfree_skb_any(skb);
--- a/drivers/net/ethernet/airoha/airoha_eth.h	2026-06-21 11:14:00.693912256 +0000
+++ b/drivers/net/ethernet/airoha/airoha_eth.h	2026-06-21 11:15:44.153001591 +0000
@@ -210,6 +210,7 @@
 	int free_thr;
 	int buf_size;
 	bool txq_stopped;
+	bool flushing;
 
 	struct napi_struct napi;
 	struct page_pool *page_pool;
