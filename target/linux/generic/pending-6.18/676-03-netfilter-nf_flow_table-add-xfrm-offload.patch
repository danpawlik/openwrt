From: Kuan-Ying Lee <kuan-ying.lee@mediatek.com>
Date: Mon, 1 Jan 2024 00:00:00 +0800
Subject: [PATCH] netfilter: add xfrm offload to nf_flow_table

Add IPsec XFRM offload support to the netfilter flow table.  This
implements FLOW_OFFLOAD_XMIT_XFRM transmit type fallthrough handling in
flow_offload_eth_{src,dst} and flow_offload_redirect, and adds
FLOW_ACTION_IPSEC_PUSH action for hardware IPsec ESP packet offload in
flow_offload_encap_tunnel.

[dpawlik: ported from mtk-openwrt-feeds 25.12 999-ppe-29]
Signed-off-by: Daniel Pawlik <pawlik.dan@gmail.com>
---
 include/net/flow_offload.h              | 10 ++++++++++
 net/netfilter/nf_flow_table_offload.c   |  4 ++++
 2 files changed, 14 insertions(+), 0 deletions(-)

--- a/include/net/flow_offload.h
+++ b/include/net/flow_offload.h
@@ -5,6 +5,7 @@
 #include <linux/list.h>
 #include <linux/netlink.h>
 #include <net/flow_dissector.h>
+#include <net/xfrm.h>

 struct flow_match {
 	struct flow_dissector	*dissector;
@@ -184,6 +185,7 @@ enum flow_action_id {
 	FLOW_ACTION_VLAN_PUSH_ETH,
 	FLOW_ACTION_VLAN_POP_ETH,
 	FLOW_ACTION_CONTINUE,
+	FLOW_ACTION_IPSEC_PUSH,
 	NUM_FLOW_ACTIONS,
 };

@@ -327,6 +329,9 @@ struct flow_action_entry {
 		struct {				/* FLOW_ACTION_PPPOE_PUSH */
 			u16		sid;
 		} pppoe;
+		struct {
+			struct xfrm_state xs;
+		} ipsec;
 	};
 	struct flow_action_cookie *user_cookie; /* user defined action cookie */
 };
--- a/net/netfilter/nf_flow_table_offload.c
+++ b/net/netfilter/nf_flow_table_offload.c
@@ -254,6 +254,7 @@ static int flow_offload_eth_src(struct n
 	case FLOW_OFFLOAD_XMIT_DIRECT:
 		addr = this_tuple->out.h_source;
 		break;
+	case FLOW_OFFLOAD_XMIT_XFRM:
 	case FLOW_OFFLOAD_XMIT_NEIGH:
 		other_tuple = &flow->tuplehash[!dir].tuple;
 		dev = dev_get_by_index(net, other_tuple->iifidx);
@@ -307,6 +308,7 @@ static int flow_offload_eth_dst(struct n
 	case FLOW_OFFLOAD_XMIT_DIRECT:
 		ether_addr_copy(ha, this_tuple->out.h_dest);
 		break;
+	case FLOW_OFFLOAD_XMIT_XFRM:
 	case FLOW_OFFLOAD_XMIT_NEIGH:
 		other_tuple = &flow->tuplehash[!dir].tuple;
 		daddr = &other_tuple->src_v4;
@@ -601,6 +603,7 @@ static int flow_offload_redirect(struct
 		this_tuple = &flow->tuplehash[dir].tuple;
 		ifindex = this_tuple->out.hw_ifidx;
 		break;
+	case FLOW_OFFLOAD_XMIT_XFRM:
 	case FLOW_OFFLOAD_XMIT_NEIGH:
 		other_tuple = &flow->tuplehash[!dir].tuple;
 		ifindex = other_tuple->iifidx;
@@ -651,6 +654,12 @@ static int flow_offload_encap_tunnel(con
 		}
 	}

+	if (dst && dst_xfrm(dst)) {
+		entry = flow_action_entry_next(flow_rule);
+		entry->id = FLOW_ACTION_IPSEC_PUSH;
+		memcpy(&entry->ipsec.xs, dst_xfrm(dst), sizeof(struct xfrm_state));
+	}
+
 	return 0;
 }
