From: Daniel Pawlik <pawlik.dan@gmail.com>
Subject: pmdomain: airoha: add PLL fallback when ATF SMC unavailable

Many AN7581 boards ship with ATF firmware that does not implement the
AVS SMC handler (0x82000301). On these boards, the PM domain driver
probes but cannot read or set CPU frequency, leaving cpufreq
non-functional.

Add direct PLL register programming as a fallback path. At probe time,
invoke SMC GET_FREQ and check the result: if it returns
SMCCC_RET_NOT_SUPPORTED or an out-of-range value, switch to PLL mode
using chip-scu and mcucfg register regions from devicetree.

The PLL fallback implements the same clock switch sequence as ATF BL31:
  1. Switch CPU to PLL2 (backup 400 MHz clock)
  2. Reprogram ARM PLL PCW and post-divider
  3. Wait for PLL lock
  4. Switch CPU back to ARM PLL

Use stop_machine() instead of local_irq_save() to ensure all CPUs are
quiesced during the PLL transition, matching the safety guarantees of
the ATF EL3 path where cores are parked via PSCI.

Signed-off-by: Daniel Pawlik <pawlik.dan@gmail.com>
---
--- a/drivers/pmdomain/mediatek/airoha-cpu-pmdomain.c
+++ b/drivers/pmdomain/mediatek/airoha-cpu-pmdomain.c
@@ -3,10 +3,14 @@
 #include <linux/arm-smccc.h>
 #include <linux/bitfield.h>
 #include <linux/clk-provider.h>
+#include <linux/delay.h>
+#include <linux/io.h>
 #include <linux/module.h>
+#include <linux/of.h>
 #include <linux/platform_device.h>
 #include <linux/pm_domain.h>
 #include <linux/slab.h>
+#include <linux/stop_machine.h>
 
 #define AIROHA_SIP_AVS_HANDLE			0x82000301
 #define AIROHA_AVS_OP_BASE			0xddddddd0
@@ -16,9 +20,51 @@
 #define AIROHA_AVS_OP_GET_FREQ			(AIROHA_AVS_OP_BASE | \
 						 FIELD_PREP(AIROHA_AVS_OP_MASK, 0x2))
 
+/* CPU PLL register offsets within chip-scu region */
+#define CPUPLL_CLK_MUX			0x1e0
+#define PLLRG_PROTECT			0x268
+#define CPUPLL_SDM_PCW			0x2b4
+#define CPUPLL_SDM_PCW_CHG		0x2b8
+
+#define CPUPLL_PCW_INT_MASK		GENMASK(30, 24)
+#define CPUPLL_XTAL_MHZ			50
+#define CPUPLL_CHG_BIT			BIT(0)
+#define CPUPLL_CHG_POSDIV_MASK		GENMASK(6, 4)
+#define PLLRG_PROTECT_MASK		GENMASK(7, 0)
+#define PLLRG_PROTECT_KEY		0x12
+
+/* MCUCFG clock switch register offsets */
+#define MCUCFG_CK_SWITCH_UNLOCK		0x640
+#define MCUCFG_CK_SOURCE_SEL		0x7c0
+
+#define MCUCFG_CK_UNLOCK_MASK		GENMASK(4, 0)
+#define MCUCFG_CK_UNLOCK_KEY		0x12
+#define MCUCFG_CK_SEL_MASK		GENMASK(10, 9)
+#define MCUCFG_CK_SEL_ARMPLL		1
+#define MCUCFG_CK_SEL_PLL2		3
+
+#define AIROHA_MIN_CPU_FREQ_MHZ		400
+#define AIROHA_MAX_CPU_FREQ_MHZ		2000
+
+/*
+ * OPP state-to-frequency mapping. Must match cpu_opp_table in DTS:
+ * state 0 = 500 MHz, state 1 = 550 MHz, ..., state 14 = 1200 MHz.
+ * ATF BL31 uses the same mapping internally for the SMC path.
+ */
+#define CPUPLL_BASE_FREQ_MHZ		500
+#define CPUPLL_STEP_FREQ_MHZ		50
+
 struct airoha_cpu_pmdomain_priv {
 	struct clk_hw hw;
 	struct generic_pm_domain pd;
+	bool use_smc;
+	void __iomem *pll_base;
+	void __iomem *mcucfg;
+};
+
+struct airoha_pll_change {
+	struct airoha_cpu_pmdomain_priv *priv;
+	unsigned int state;
 };
 
 static int airoha_cpu_pmdomain_clk_determine_rate(struct clk_hw *hw,
@@ -27,16 +73,30 @@
 	return 0;
 }
 
+static unsigned long airoha_cpu_pll_clk_get(struct airoha_cpu_pmdomain_priv *priv)
+{
+	u32 pcw = readl(priv->pll_base + CPUPLL_SDM_PCW);
+	u32 chg = readl(priv->pll_base + CPUPLL_SDM_PCW_CHG);
+	unsigned int pcw_int = FIELD_GET(CPUPLL_PCW_INT_MASK, pcw);
+	unsigned int posdiv = FIELD_GET(CPUPLL_CHG_POSDIV_MASK, chg);
+
+	return ((unsigned long)pcw_int * CPUPLL_XTAL_MHZ * 1000000UL) >> posdiv;
+}
+
 static unsigned long airoha_cpu_pmdomain_clk_get(struct clk_hw *hw,
 						 unsigned long parent_rate)
 {
+	struct airoha_cpu_pmdomain_priv *priv =
+		container_of(hw, struct airoha_cpu_pmdomain_priv, hw);
 	struct arm_smccc_res res;
 
-	arm_smccc_1_1_invoke(AIROHA_SIP_AVS_HANDLE, AIROHA_AVS_OP_GET_FREQ,
-			     0, 0, 0, 0, 0, 0, &res);
+	if (!priv->use_smc)
+		return airoha_cpu_pll_clk_get(priv);
 
-	/* SMCCC returns freq in MHz */
-	return (int)(res.a0 * 1000 * 1000);
+	arm_smccc_1_1_invoke(AIROHA_SIP_AVS_HANDLE,
+			     AIROHA_AVS_OP_GET_FREQ,
+			     0, 0, 0, 0, 0, 0, &res);
+	return (unsigned long)(res.a0 * 1000000UL);
 }
 
 /* Airoha CPU clk SMCC is always enabled */
@@ -51,16 +111,102 @@
 	.determine_rate = airoha_cpu_pmdomain_clk_determine_rate,
 };
 
+/*
+ * Switch CPU clock source. Mirrors ATF BL31 clock_switch() sequence.
+ */
+static void airoha_cpu_clock_switch(void __iomem *pll_base,
+				    void __iomem *mcucfg, unsigned int sel)
+{
+	u32 val;
+
+	if (sel != 0) {
+		val = readl(pll_base + CPUPLL_CLK_MUX);
+		writel(val | BIT(sel - 1), pll_base + CPUPLL_CLK_MUX);
+	}
+
+	val = readl(mcucfg + MCUCFG_CK_SWITCH_UNLOCK);
+	writel((val & ~MCUCFG_CK_UNLOCK_MASK) | MCUCFG_CK_UNLOCK_KEY,
+	       mcucfg + MCUCFG_CK_SWITCH_UNLOCK);
+
+	val = readl(mcucfg + MCUCFG_CK_SOURCE_SEL);
+	val &= ~MCUCFG_CK_SEL_MASK;
+	val |= FIELD_PREP(MCUCFG_CK_SEL_MASK, sel);
+	writel(val, mcucfg + MCUCFG_CK_SOURCE_SEL);
+}
+
+/*
+ * stop_machine callback: runs on one CPU, all others in spinloop.
+ * Frequency from CPUPLL_BASE_FREQ_MHZ + state * CPUPLL_STEP_FREQ_MHZ.
+ * VCO must stay >= 1000 MHz:
+ *   < 1000: posdiv=1, pcw = freq/25
+ *   >= 1000: posdiv=0, pcw = freq/50
+ */
+static int airoha_cpu_pll_set_freq_cb(void *data)
+{
+	struct airoha_pll_change *chg = data;
+	struct airoha_cpu_pmdomain_priv *priv = chg->priv;
+	void __iomem *base = priv->pll_base;
+	unsigned int freq_mhz = CPUPLL_BASE_FREQ_MHZ + chg->state * CPUPLL_STEP_FREQ_MHZ;
+	unsigned int posdiv, pcw_int;
+	u32 val, old_chg, new_chg;
+
+	if (freq_mhz < 1000) {
+		posdiv = 1;
+		pcw_int = freq_mhz / 25;
+	} else {
+		posdiv = 0;
+		pcw_int = freq_mhz / 50;
+	}
+
+	airoha_cpu_clock_switch(base, priv->mcucfg, MCUCFG_CK_SEL_PLL2);
+
+	val = readl(base + PLLRG_PROTECT);
+	writel((val & ~PLLRG_PROTECT_MASK) | PLLRG_PROTECT_KEY,
+	       base + PLLRG_PROTECT);
+
+	val = readl(base + CPUPLL_SDM_PCW);
+	val &= ~CPUPLL_PCW_INT_MASK;
+	val |= FIELD_PREP(CPUPLL_PCW_INT_MASK, pcw_int);
+	writel(val, base + CPUPLL_SDM_PCW);
+
+	old_chg = readl(base + CPUPLL_SDM_PCW_CHG);
+	new_chg = old_chg & ~(CPUPLL_CHG_POSDIV_MASK | CPUPLL_CHG_BIT);
+	new_chg |= FIELD_PREP(CPUPLL_CHG_POSDIV_MASK, posdiv);
+	if (!(old_chg & CPUPLL_CHG_BIT))
+		new_chg |= CPUPLL_CHG_BIT;
+	writel(new_chg, base + CPUPLL_SDM_PCW_CHG);
+
+	udelay(20);
+
+	airoha_cpu_clock_switch(base, priv->mcucfg, MCUCFG_CK_SEL_ARMPLL);
+
+	val = readl(base + CPUPLL_CLK_MUX);
+	writel(val & ~BIT(MCUCFG_CK_SEL_PLL2 - 1), base + CPUPLL_CLK_MUX);
+
+	val = readl(base + PLLRG_PROTECT);
+	writel(val & ~PLLRG_PROTECT_MASK, base + PLLRG_PROTECT);
+
+	return 0;
+}
+
 static int airoha_cpu_pmdomain_set_performance_state(struct generic_pm_domain *domain,
 						     unsigned int state)
 {
+	struct airoha_cpu_pmdomain_priv *priv =
+		container_of(domain, struct airoha_cpu_pmdomain_priv, pd);
+	struct airoha_pll_change pll_data;
 	struct arm_smccc_res res;
 
-	arm_smccc_1_1_invoke(AIROHA_SIP_AVS_HANDLE, AIROHA_AVS_OP_FREQ_DYN_ADJ,
-			     0, state, 0, 0, 0, 0, &res);
-
-	/* SMC signal correct apply by unsetting BIT 0 */
-	return res.a0 & BIT(0) ? -EINVAL : 0;
+	if (priv->use_smc) {
+		arm_smccc_1_1_invoke(AIROHA_SIP_AVS_HANDLE,
+				     AIROHA_AVS_OP_FREQ_DYN_ADJ,
+				     0, state, 0, 0, 0, 0, &res);
+		return res.a0 & BIT(0) ? -EINVAL : 0;
+	}
+
+	pll_data = (struct airoha_pll_change){ .priv = priv, .state = state };
+	return stop_machine(airoha_cpu_pll_set_freq_cb, &pll_data,
+			    cpu_online_mask);
 }
 
 static int airoha_cpu_pmdomain_probe(struct platform_device *pdev)
@@ -74,14 +220,53 @@
 		.flags = CLK_GET_RATE_NOCACHE,
 	};
 	struct generic_pm_domain *pd;
+	struct arm_smccc_res res;
+	unsigned long freq_hz;
 	int ret;
 
 	priv = devm_kzalloc(dev, sizeof(*priv), GFP_KERNEL);
 	if (!priv)
 		return -ENOMEM;
 
-	/* Init and register a get-only clk for Cpufreq */
+	arm_smccc_1_1_invoke(AIROHA_SIP_AVS_HANDLE, AIROHA_AVS_OP_GET_FREQ,
+			     0, 0, 0, 0, 0, 0, &res);
+
+	if ((long)res.a0 != SMCCC_RET_NOT_SUPPORTED &&
+	    res.a0 >= AIROHA_MIN_CPU_FREQ_MHZ &&
+	    res.a0 < AIROHA_MAX_CPU_FREQ_MHZ) {
+		priv->use_smc = true;
+		dev_info(dev, "using ATF SMC for CPU frequency control\n");
+	} else {
+		priv->use_smc = false;
+
+		priv->pll_base = devm_platform_ioremap_resource_byname(pdev,
+								       "chip-scu");
+		if (IS_ERR(priv->pll_base))
+			return dev_err_probe(dev, PTR_ERR(priv->pll_base),
+					     "ATF SMC unavailable, no chip-scu reg\n");
+
+		priv->mcucfg = devm_platform_ioremap_resource_byname(pdev,
+								     "mcucfg");
+		if (IS_ERR(priv->mcucfg))
+			return dev_err_probe(dev, PTR_ERR(priv->mcucfg),
+					     "ATF SMC unavailable, no mcucfg reg\n");
+
+		dev_info(dev, "ATF SMC unavailable, using direct PLL\n");
+	}
+
 	priv->hw.init = &init;
+	freq_hz = airoha_cpu_pmdomain_clk_get(&priv->hw, 0);
+	if (!freq_hz || freq_hz > AIROHA_MAX_CPU_FREQ_MHZ * 1000000UL)
+		return dev_err_probe(dev, -ENODEV,
+				     "invalid CPU freq: %lu Hz\n", freq_hz);
+
+	dev_info(dev, "CPU at %lu MHz\n", freq_hz / 1000000);
+
+	if (!priv->use_smc &&
+	    (freq_hz / 1000000 - CPUPLL_BASE_FREQ_MHZ) % CPUPLL_STEP_FREQ_MHZ)
+		dev_warn(dev, "boot freq %lu MHz doesn't align with OPP step\n",
+			 freq_hz / 1000000);
+
 	ret = devm_clk_hw_register(dev, &priv->hw);
 	if (ret)
 		return ret;
