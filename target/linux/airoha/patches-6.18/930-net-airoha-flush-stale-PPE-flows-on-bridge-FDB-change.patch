From: Daniel Pawlik <pawlik.dan@gmail.com>
Date: Mon, 30 Jun 2026 12:00:00 +0200
Subject: [PATCH] net: airoha: flush stale PPE L2 flows on bridge FDB change

When a WiFi station roams or disconnects, stale PPE flow entries keep
directing traffic to the old bridge port, collapsing throughput to ~1 Mbit/s.
Two problems compound:

1. bridger's RTM_DELTFILTER fails silently while the PPE has the flow
   BIND-active (NPU firmware rejects SRAM invalidation), leaving a stale
   skip_sw TC filter that dead-ends downstream traffic.

2. After the PPE auto-ages the BIND entry, airoha_ppe_foe_insert_entry()
   re-establishes hardware offload in the wrong direction via the stale
   L2 parent still in l2_flows.

Register a switchdev notifier on SWITCHDEV_FDB_ADD_TO_DEVICE (roaming) and
SWITCHDEV_FDB_DEL_TO_DEVICE (disconnect) that pre-emptively removes the
driver's software flow state for the affected MAC from flow_table and l2_flows:

 - Removing the flow_table entry makes airoha_ppe_flow_offload_destroy()
   return -ENOENT on the next RTM_DELTFILTER; the TC layer removes the
   software filter state without needing to fight the bound SRAM entry.

 - Removing the l2_flows entry prevents airoha_ppe_foe_insert_entry() from
   re-learning the stale direction after the BIND entry ages out.

L3 conntrack flows (FLOW_TYPE_L4, managed by nf_flow_table) have their own
aging and self-correct without intervention.

The O(n) walk borrows the unused l2_subflow_node field as a scratch hlist_node
to collect matches while holding the iterator, then processes after releasing it.
The atomic notifier defers work to a private ordered workqueue.

Signed-off-by: Daniel Pawlik <pawlik.dan@gmail.com>
---
 drivers/net/ethernet/airoha/airoha_eth.h |   3 +
 drivers/net/ethernet/airoha/airoha_ppe.c | 101 ++++++++++++++++++++++++++++++
 2 files changed, 104 insertions(+)

--- a/drivers/net/ethernet/airoha/airoha_eth.h
+++ b/drivers/net/ethernet/airoha/airoha_eth.h
@@ -13,6 +13,7 @@
 #include <linux/kernel.h>
 #include <linux/netdevice.h>
 #include <linux/reset.h>
+#include <linux/workqueue.h>
 #include <linux/soc/airoha/airoha_offload.h>
 #include <net/dsa.h>
 
@@ -593,6 +594,8 @@
 
 	struct airoha_ppe *ppe;
 	struct rhashtable flow_table;
+	struct notifier_block switchdev_nb;
+	struct workqueue_struct *fdb_wq;
 
 	struct reset_control_bulk_data rsts[AIROHA_MAX_NUM_RSTS];
 	struct reset_control_bulk_data *xsi_rsts;
--- a/drivers/net/ethernet/airoha/airoha_ppe.c
+++ b/drivers/net/ethernet/airoha/airoha_ppe.c
@@ -13,6 +13,7 @@
 #include <linux/if_vlan.h>
 #include <net/pkt_cls.h>
 #include <net/route.h>
+#include <net/switchdev.h>

 #include "airoha_regs.h"
 #include "airoha_eth.h"
@@ -1306,6 +1307,89 @@
 	return npu->ops.ppe_flush_sram_entries(npu, ppe->foe_dma,
 					       sram_num_entries);
 }
+/* ---- switchdev notifier: flush stale PPE L2 flows on bridge FDB change --- */
+
+struct airoha_ppe_fdb_work {
+	struct work_struct work;
+	struct airoha_eth *eth;
+	u8 addr[ETH_ALEN];
+};
+
+static bool airoha_ppe_l2_flow_has_mac(const struct airoha_flow_table_entry *e,
+				     const u8 *addr)
+{
+	const struct airoha_foe_bridge *br = &e->data.bridge;
+
+	if (get_unaligned_be32(addr)     == br->dest_mac_hi &&
+	    get_unaligned_be16(addr + 4) == br->dest_mac_lo)
+		return true;
+	if (get_unaligned_be16(addr)     == br->src_mac_hi &&
+	    get_unaligned_be32(addr + 2) == br->src_mac_lo)
+		return true;
+	return false;
+}
+
+static void airoha_ppe_flush_l2_flows_by_mac(struct airoha_eth *eth, const u8 *addr)
+{
+	struct airoha_ppe *ppe = eth->ppe;
+	struct airoha_flow_table_entry *e;
+	struct hlist_node *tmp;
+	HLIST_HEAD(to_remove);
+	struct rhashtable_iter iter;
+
+	lockdep_assert_held(&flow_offload_mutex);
+
+	rhashtable_walk_enter(&ppe->l2_flows, &iter);
+	rhashtable_walk_start(&iter);
+	while ((e = rhashtable_walk_next(&iter)) != NULL) {
+		if (!IS_ERR(e) && airoha_ppe_l2_flow_has_mac(e, addr))
+			hlist_add_head(&e->l2_subflow_node, &to_remove);
+	}
+	rhashtable_walk_stop(&iter);
+	rhashtable_walk_exit(&iter);
+
+	hlist_for_each_entry_safe(e, tmp, &to_remove, l2_subflow_node) {
+		hlist_del_init(&e->l2_subflow_node);
+		airoha_ppe_foe_flow_remove_entry(ppe, e);
+		rhashtable_remove_fast(&eth->flow_table, &e->node, airoha_flow_table_params);
+		kfree(e);
+	}
+}
+
+static void airoha_ppe_fdb_work_handler(struct work_struct *work)
+{
+	struct airoha_ppe_fdb_work *w = container_of(work, struct airoha_ppe_fdb_work, work);
+
+	mutex_lock(&flow_offload_mutex);
+	if (w->eth->npu)
+		airoha_ppe_flush_l2_flows_by_mac(w->eth, w->addr);
+	mutex_unlock(&flow_offload_mutex);
+	kfree(w);
+}
+
+static int airoha_ppe_switchdev_event(struct notifier_block *nb,
+				      unsigned long event, void *ptr)
+{
+	struct airoha_eth *eth = container_of(nb, struct airoha_eth, switchdev_nb);
+	const struct switchdev_notifier_fdb_info *fdb_info = ptr;
+	struct airoha_ppe_fdb_work *w;
+
+	if (event != SWITCHDEV_FDB_ADD_TO_DEVICE && event != SWITCHDEV_FDB_DEL_TO_DEVICE)
+		return NOTIFY_DONE;
+	if (fdb_info->is_local || is_multicast_ether_addr(fdb_info->addr))
+		return NOTIFY_DONE;
+
+	w = kmalloc(sizeof(*w), GFP_ATOMIC);
+	if (!w)
+		return NOTIFY_BAD;
+
+	INIT_WORK(&w->work, airoha_ppe_fdb_work_handler);
+	w->eth = eth;
+	ether_addr_copy(w->addr, fdb_info->addr);
+	queue_work(eth->fdb_wq, &w->work);
+	return NOTIFY_DONE;
+}
+
 
 static struct airoha_npu *airoha_ppe_npu_get(struct airoha_eth *eth)
 {
@@ -1555,8 +1639,22 @@
 	if (err)
 		goto error_l2_flow_table_destroy;
 
+	eth->fdb_wq = alloc_ordered_workqueue("airoha_ppe_fdb", 0);
+	if (!eth->fdb_wq) {
+		err = -ENOMEM;
+		goto error_debugfs_destroy;
+	}
+	eth->switchdev_nb.notifier_call = airoha_ppe_switchdev_event;
+	err = register_switchdev_notifier(&eth->switchdev_nb);
+	if (err)
+		goto error_wq_destroy;
+
 	return 0;
 
+error_wq_destroy:
+	destroy_workqueue(eth->fdb_wq);
+error_debugfs_destroy:
+	debugfs_remove(ppe->debugfs_dir);
 error_l2_flow_table_destroy:
 	rhashtable_destroy(&ppe->l2_flows);
 error_flow_table_destroy:
@@ -1569,6 +1667,9 @@
 {
 	struct airoha_npu *npu;
 
+	unregister_switchdev_notifier(&eth->switchdev_nb);
+	destroy_workqueue(eth->fdb_wq);
+
 	mutex_lock(&flow_offload_mutex);
 
 	npu = rcu_replace_pointer(eth->npu, NULL,
